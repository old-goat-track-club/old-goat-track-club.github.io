{
  "name": "old-goat-track-club",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 8000 --host",
    "format": "prettier --write .",
    "format-watch": "onchange --await-write-finish 5000 \"**/*\" -- prettier --write --ignore-unknown {{changed}}"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "vite": "^6.2.0",
    "onchange": "^7.1.0"
  }
}
